{
  "name": "voiceink",
  "version": "1.0.0",
  "description": "Intelligent voice-to-text dictation app with LLM post-processing",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "vite",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "start": "electron dist/main/index.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "@electron/remote": "^2.1.2",
    "@tailwindcss/oxide-linux-x64-gnu": "^4.2.2",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.9",
    "sql.js": "^1.11.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "lucide-react": "^0.460.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "zustand": "^5.0.2"
  },
  "build": {
    "appId": "com.voiceink.app",
    "productName": "VoiceInk",
    "copyright": "Copyright © 2026 VoiceInk",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "models/**/*"
    ],
    "asar": true,
    "asarUnpack": [
      "dist/main/engines/whisper_server.py",
      "node_modules/sql.js/**/*.wasm",
      "node_modules/@electron/remote/**/*"
    ],
    "compression": "maximum",
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        },
        {
          "target": "zip",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.ico",
      "artifactName": "VoiceInk-${version}-${arch}.${ext}",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        {
          "target": "zip",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.productivity",
      "artifactName": "VoiceInk-${version}-mac.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.png",
      "category": "Utility",
      "artifactName": "VoiceInk-${version}.${ext}",
      "desktop": {
        "Name": "VoiceInk",
        "Comment": "Dictée vocale intelligente avec post-traitement LLM",
        "Categories": "AudioVideo;Utility;",
        "Keywords": "voice;dictation;transcription;whisper;",
        "StartupNotify": "true"
      }
    }
  }
}
