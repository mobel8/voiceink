{
  "name": "voiceink-server",
  "version": "0.1.0",
  "description": "VoiceInk SaaS backend — auth, billing, quotas, broker for Groq/Cartesia/ElevenLabs",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:push": "node scripts/db-push.js",
    "db:seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/multipart": "^9.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "@fastify/sensible": "^6.0.1",
    "@fastify/type-provider-typebox": "^5.0.0",
    "@sinclair/typebox": "^0.33.17",
    "dotenv": "^16.4.5",
    "fastify": "^5.1.0",
    "jose": "^5.9.6",
    "pino-pretty": "^13.0.0",
    "postgres": "^3.4.5",
    "stripe": "^17.4.0",
    "undici": "^6.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
