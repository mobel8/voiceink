# VoiceInk backend configuration — COPY TO .env AND FILL IN
#
# ────────────────────────────────────────────────────────────────
#  Core
# ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8787
# Origin allowed for CORS. In production, set to https://app.voiceink.app.
# The Electron app uses `file://` so CORS doesn't apply there — only the
# web dashboard needs this.
CORS_ORIGIN=http://localhost:5173

# ────────────────────────────────────────────────────────────────
#  Database — Postgres via postgres.js (any provider works)
# ────────────────────────────────────────────────────────────────
# Local dev: `docker run -d --name pg -e POSTGRES_PASSWORD=dev -p 5432:5432 postgres:16`
DATABASE_URL=postgres://postgres:dev@localhost:5432/voiceink

# ────────────────────────────────────────────────────────────────
#  Auth — Clerk (https://clerk.com, free tier up to 10k MAU)
# ────────────────────────────────────────────────────────────────
# The JWKS URL is used to verify Clerk-issued JWTs on every API call.
# Find it at https://dashboard.clerk.com/last-active?path=api-keys
CLERK_JWKS_URL=https://example.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://example.clerk.accounts.dev

# ────────────────────────────────────────────────────────────────
#  Stripe — https://dashboard.stripe.com
# ────────────────────────────────────────────────────────────────
# Use test keys (sk_test_… / pk_test_…) until going live.
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
# Price IDs — create 3 products in Stripe Dashboard and paste their price
# IDs here. The plan keys MUST match the `Plan` enum in src/billing/plans.ts.
STRIPE_PRICE_PRO_MONTHLY=price_REPLACE_ME
STRIPE_PRICE_PRO_YEARLY=price_REPLACE_ME
STRIPE_PRICE_TEAM_MONTHLY=price_REPLACE_ME

# ────────────────────────────────────────────────────────────────
#  Provider broker — the keys we use to serve Free/Pro users
# ────────────────────────────────────────────────────────────────
# These are OUR keys, billed to OUR Stripe account, used for every Pro
# request. Free users get capped access. Users on an "enterprise/BYOK"
# plan bypass this and send their own keys from the desktop app.
GROQ_API_KEY=gsk_REPLACE_ME
CARTESIA_API_KEY=sk_car_REPLACE_ME
ELEVENLABS_API_KEY=el_REPLACE_ME
OPENAI_API_KEY=sk-REPLACE_ME

# ────────────────────────────────────────────────────────────────
#  Quota enforcement (in-memory for dev, swap to Redis in prod)
# ────────────────────────────────────────────────────────────────
# REDIS_URL=rediss://default:pass@example.upstash.io:6379
