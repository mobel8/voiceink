---
/**
 * BaseLayout — every page wraps in this.
 *
 * Responsibilities:
 *  - Boot the font stack (Inter Variable + Geist + JetBrains Mono from
 *    the `@fontsource` CDN for instant FOUT-free rendering).
 *  - Inject meta tags (OG, Twitter, description, canonical).
 *  - Mount the sticky Nav + Footer so pages only provide the body.
 *  - Set the color-scheme meta so Safari adjusts its title bar tint.
 *  - Prevent the "white flash" on slow network by painting the dark
 *    background via the inline <style> BEFORE the external CSS loads.
 *
 * CSS pipeline:
 *  - We pre-compile src/styles/global.css with the standalone
 *    `tailwindcss` CLI into `public/styles/app.css`. Astro serves it
 *    as a static asset under `/styles/app.css`. Bypassing Vite's CSS
 *    pipeline entirely proved more reliable than @astrojs/tailwind
 *    which silently dropped our CSS output under Astro 5 on Windows.
 *  - During `npm run dev` a sidecar `watch:css` script recompiles on
 *    every change (<1s), giving us effective HMR.
 */
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title,
  description = 'VoiceInk — the fastest voice-to-voice translator on your desktop. Dictation, interpreter and live listener in one beautiful app.',
  canonical,
  ogImage = '/og/voiceink-og.png',
} = Astro.props;

const siteUrl = 'https://voiceink.app';
const canonicalUrl = canonical ?? `${siteUrl}${Astro.url.pathname}`;
---

<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#05060f" />
    <meta name="color-scheme" content="dark" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />

    {/* Avoid FOUC on slow 3G — paint the dark body background before CSS. */}
    <style is:inline>
      html { background: #050816; color-scheme: dark; }
      body { background: #050816; color: #e8ecf5; margin: 0; }
    </style>

    {/* Main stylesheet — compiled by `npm run build:css` from
        src/styles/global.css into public/styles/app.css. */}
    <link rel="stylesheet" href="/styles/app.css" />

    <title>{title}</title>
    <meta name="description" content={description} />

    {/* Open Graph */}
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url"         content={canonicalUrl} />
    <meta property="og:image"       content={`${siteUrl}${ogImage}`} />
    <meta property="og:type"        content="website" />
    <meta property="og:site_name"   content="VoiceInk" />

    {/* Twitter */}
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={`${siteUrl}${ogImage}`} />

    {/* Fonts — Inter Variable + Geist + JetBrains Mono.
        We use Google Fonts for simplicity of shipping; swap to
        self-hosted @fontsource once the landing moves to Cloudflare R2. */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    />

    {/* Analytics — plug Plausible here when live. Free, privacy-safe,
        GDPR-ok without a cookie banner. */}
    {/* <script defer data-domain="voiceink.app" src="https://plausible.io/js/script.js"></script> */}
  </head>

  <body class="min-h-dvh overflow-x-hidden antialiased">
    <Nav />
    <main class="relative">
      <slot />
    </main>
    <Footer />

    {/*
      Tiny enhancement script — runs after body, no dependencies.

      1. Scroll-reveal: any element with `data-reveal` starts at
         opacity 0 / translateY(16px) and eases in when it crosses
         into the viewport. IntersectionObserver is supported in
         every browser we target, gated by prefers-reduced-motion.

      2. Card tilt: any `.glass-tilt` card gets a gentle 3D tilt
         that follows the cursor. Uses rAF to stay butter-smooth,
         pointerleave resets the transform. Disabled on touch
         (coarse pointer media query) where hover isn't meaningful.

      Kept as inline script (no build step, no cache lookup) so
      it boots before the largest above-the-fold images paint.
    */}
    <script is:inline>
      (function () {
        'use strict';
        const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        /* ---- Scroll reveal ---------------------------------------- */
        const revealTargets = document.querySelectorAll('[data-reveal]');
        if (revealTargets.length && 'IntersectionObserver' in window && !reducedMotion) {
          const io = new IntersectionObserver(
            (entries) => {
              for (const e of entries) {
                if (e.isIntersecting) {
                  e.target.classList.add('is-revealed');
                  io.unobserve(e.target);
                }
              }
            },
            { rootMargin: '0px 0px -8% 0px', threshold: 0.12 }
          );
          revealTargets.forEach((el) => io.observe(el));
        } else {
          // Fallback: show everything immediately.
          revealTargets.forEach((el) => el.classList.add('is-revealed'));
        }

        /* ---- Pointer tilt ----------------------------------------- */
        const fineHover = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
        if (fineHover && !reducedMotion) {
          const cards = document.querySelectorAll('.glass-tilt');
          cards.forEach((card) => {
            let raf = 0;
            let pending = null;
            const onMove = (ev) => {
              const rect = card.getBoundingClientRect();
              const px = (ev.clientX - rect.left) / rect.width;
              const py = (ev.clientY - rect.top)  / rect.height;
              pending = { px, py };
              if (!raf) raf = requestAnimationFrame(apply);
            };
            const apply = () => {
              raf = 0;
              if (!pending) return;
              const rx = (0.5 - pending.py) * 6;   // vertical axis
              const ry = (pending.px - 0.5) * 8;   // horizontal axis
              card.style.transform =
                'perspective(900px) rotateX(' + rx.toFixed(2) + 'deg) rotateY(' + ry.toFixed(2) + 'deg) translateY(-2px)';
            };
            const reset = () => {
              if (raf) cancelAnimationFrame(raf);
              raf = 0;
              pending = null;
              card.style.transform = '';
            };
            card.addEventListener('pointermove', onMove, { passive: true });
            card.addEventListener('pointerleave', reset);
          });
        }
      })();
    </script>
  </body>
</html>
