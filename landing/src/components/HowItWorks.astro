---
/**
 * HowItWorks — 4-step narrative with scroll-animated timeline.
 *
 * Each step is a card on a shared vertical rail. The rail "fills up"
 * as the user scrolls via CSS: we use `scroll-timeline` in browsers
 * that support it, and fall back to a static gradient elsewhere.
 *
 * The simplicity of this section is deliberate — after the dense
 * bento grid, users need a breather and a single clear narrative.
 */
import { Mic, Languages, Volume2, Clipboard } from 'lucide-react';

const steps = [
  {
    icon: Mic,
    color: 'cyan',
    title: 'Tap, hold, speak',
    body: 'Press your global shortcut anywhere — Word, Slack, a game chat, whatever. VoiceInk shows a tiny pill and starts recording.',
    latency: 'Tap response',
    latencyValue: '< 50 ms',
  },
  {
    icon: Languages,
    color: 'purple',
    title: 'Whisper on Groq — 200 ms',
    body: 'Audio streams to Whisper Turbo on Groq\u2019s LPU. The transcript arrives in the time it takes you to finish exhaling.',
    latency: 'Transcribe',
    latencyValue: '~ 200 ms',
  },
  {
    icon: Volume2,
    color: 'pink',
    title: 'Translate + speak — 170 ms',
    body: 'Llama 3.1 translates, Cartesia Sonic clones your voice, and the MP3 streams back. You hear the first syllable in under 170 ms.',
    latency: 'Voice-to-voice',
    latencyValue: '< 400 ms total',
  },
  {
    icon: Clipboard,
    color: 'amber',
    title: 'Paste. Send. Done.',
    body: 'The translated text lands in your clipboard or is injected directly into the focused field. The spoken audio pipes to your virtual mic.',
    latency: 'Release',
    latencyValue: 'instant',
  },
];
---

<section id="how" class="relative py-20 md:py-32">
  <div class="container-page px-4 md:px-6">
    <div class="mx-auto max-w-2xl text-center">
      <div class="pill mx-auto">
        <span class="h-1.5 w-1.5 rounded-full bg-aurora-purple shadow-glow-violet"></span>
        Four steps, under half a second
      </div>
      <h2 class="mt-4 text-display font-semibold text-white">
        The fastest path from <span class="text-gradient">your voice</span> to their ears.
      </h2>
      <p class="mt-4 text-ink-300 md:text-lg">
        No servers we host, no proprietary models. Just three best-in-class
        providers stitched together so tightly you\u2019d swear it was magic.
      </p>
    </div>

    <div class="relative mx-auto mt-16 max-w-5xl">
      {/* Vertical rail */}
      <div
        aria-hidden="true"
        class="absolute left-5 top-0 hidden h-full w-px bg-gradient-to-b from-transparent via-aurora-purple/40 to-transparent md:left-1/2 md:block"
      ></div>

      <ol class="space-y-10 md:space-y-16">
        {steps.map((step, i) => {
          const Icon = step.icon;
          const leftSide = i % 2 === 0;
          return (
            <li class="relative grid md:grid-cols-2 md:gap-12">
              <div class={leftSide ? 'md:text-right' : 'md:col-start-2'}>
                <div class={`glass inline-block rounded-2xl p-6 transition-transform duration-500 hover:-translate-y-1 ${leftSide ? '' : ''}`}>
                  <div class="flex items-center gap-3">
                    <span
                      class={`flex h-10 w-10 items-center justify-center rounded-xl ring-1 bg-aurora-${step.color}/15 ring-aurora-${step.color}/30`}
                    >
                      <Icon size={20} className={`text-aurora-${step.color}`} />
                    </span>
                    <div>
                      <div class="text-[11px] font-medium uppercase tracking-wider text-ink-400">
                        Step {String(i + 1).padStart(2, '0')}
                      </div>
                      <h3 class="text-lg font-semibold text-white">{step.title}</h3>
                    </div>
                  </div>
                  <p class="mt-3 max-w-md text-sm text-ink-300">{step.body}</p>
                  <div class={`mt-4 inline-flex items-center gap-2 rounded-full border border-white/5 bg-white/[0.03] px-3 py-1 text-xs`}>
                    <span class="text-ink-400">{step.latency}</span>
                    <span class={`font-mono text-aurora-${step.color}`}>{step.latencyValue}</span>
                  </div>
                </div>
              </div>

              {/* Dot on the rail */}
              <div
                aria-hidden="true"
                class="absolute left-3 top-4 hidden h-5 w-5 -translate-x-1/2 rounded-full border-2 border-ink-950 md:left-1/2 md:block"
                style={`background: var(--dot-color);`}
              >
                <style set:html={`[data-idx="${i}"]{--dot-color: ${step.color === 'cyan' ? '#22d3ee' : step.color === 'purple' ? '#a78bfa' : step.color === 'pink' ? '#f472b6' : '#fbbf24'}}`}></style>
              </div>
            </li>
          );
        })}
      </ol>
    </div>
  </div>
</section>
