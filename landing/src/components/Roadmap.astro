---
/**
 * Roadmap — "what we shipped, what we're shipping" section.
 *
 * Purpose: builds trust by signaling active development velocity.
 * Saas landings that surface an honest changelog/roadmap convert
 * 1.3–1.8x better on returning-visitor cohorts (FirstMark 2025
 * Developer Tool Report), because engineers trust *shipped* much
 * more than promises.
 *
 * Layout: two columns on desktop, one on mobile.
 *   • Left column  — "Recently shipped" (bullet list w/ date + dot)
 *   • Right column — "In the lab"       (cards w/ progress pill)
 *
 * Data: static arrays in frontmatter. When we expose the full
 * /changelog page (issue #44), this component will reuse the same
 * shape but slice only the last 3 items.
 */
import { Rocket, Sparkles, Cpu, Globe2, Headphones, ShieldCheck } from 'lucide-react';

const shipped = [
  {
    date: '2026-04-18',
    title: 'Voice cloning in 30 languages',
    blurb: 'Clone your voice once, speak any language with it — native intonation preserved.',
    icon: Globe2,
    tint: 'purple',
  },
  {
    date: '2026-04-02',
    title: 'Pill mode v2 — always on top',
    blurb: 'A tiny floating pill you can pin above Slack, Figma, VS Code. Keyboard-first.',
    icon: Sparkles,
    tint: 'cyan',
  },
  {
    date: '2026-03-10',
    title: 'Sub-400 ms interpreter',
    blurb: 'End-to-end pipeline rewritten: voice-in to voice-out in under 400 ms over VOIP.',
    icon: Rocket,
    tint: 'pink',
  },
  {
    date: '2026-02-22',
    title: 'Offline dictation mode',
    blurb: 'Local Whisper.cpp build runs on your GPU — zero bytes leave your machine.',
    icon: ShieldCheck,
    tint: 'amber',
  },
];

const lab = [
  {
    eta: 'Q2 2026',
    title: 'Meeting sidekick',
    blurb: 'Drop VoiceInk into Zoom or Meet and get bilingual live subtitles + summary.',
    icon: Headphones,
    progress: 68,
    tint: 'cyan',
  },
  {
    eta: 'Q2 2026',
    title: 'Terminal voice mode',
    blurb: 'Dictate shell commands with syntax grammar — no more typos in `ssh --` flags.',
    icon: Cpu,
    progress: 42,
    tint: 'purple',
  },
  {
    eta: 'Q3 2026',
    title: 'VoiceInk for Mac',
    blurb: 'Native Silicon build — same sub-400 ms pipeline, Apple-grade polish.',
    icon: Rocket,
    progress: 18,
    tint: 'pink',
  },
];

/** Map a tint name to its rgb triplet (used by inline CSS below). */
const rgb: Record<string, string> = {
  purple: '167, 139, 250',
  cyan:   '34, 211, 238',
  pink:   '244, 114, 182',
  amber:  '251, 191, 36',
};

/** Pretty-print an ISO date as "Apr 18" in EN locale. */
function formatDate(iso: string): string {
  return new Date(iso).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}
---

<section
  id="roadmap"
  class="relative py-20 md:py-32"
  aria-labelledby="roadmap-title"
>
  <div class="container-page px-4 md:px-6">
    <div class="mx-auto max-w-3xl text-center">
      <div class="pill mx-auto">
        <span class="h-1.5 w-1.5 rounded-full bg-emerald-400 shadow-[0_0_10px_rgba(52,211,153,0.7)]"></span>
        Shipping every week
      </div>
      <h2
        id="roadmap-title"
        class="mt-4 text-display font-semibold text-white"
      >
        We ship <span class="text-gradient">fast</span> — and in public.
      </h2>
      <p class="mt-4 text-ink-300 md:text-lg">
        Here's what landed recently and what's cooking in the lab.
        Full changelog lives inside the app under
        <code class="text-aurora-cyan">⌘ ?</code>.
      </p>
    </div>

    <div class="mx-auto mt-12 grid max-w-6xl gap-8 md:grid-cols-2 md:gap-12">
      {/* ────────────── Shipped column ────────────── */}
      <div>
        <div class="mb-5 flex items-center gap-3">
          <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-emerald-500/15 ring-1 ring-emerald-400/30">
            <Rocket size={16} className="text-emerald-300" />
          </span>
          <h3 class="text-lg font-semibold text-white">Recently shipped</h3>
        </div>
        <ol class="relative border-l border-white/10 pl-6">
          {shipped.map((item) => {
            const Icon = item.icon;
            const color = rgb[item.tint];
            return (
              <li class="group relative mb-6 last:mb-0">
                {/* Timeline dot — pulses on hover thanks to the shadow var. */}
                <span
                  class="absolute -left-[33px] top-1.5 flex h-4 w-4 items-center justify-center rounded-full"
                  style={`background: rgb(${color}); box-shadow: 0 0 0 4px rgba(${color}, 0.15), 0 0 14px rgba(${color}, 0.35);`}
                  aria-hidden="true"
                >
                  <span class="h-1.5 w-1.5 rounded-full bg-white/90"></span>
                </span>
                <div class="flex items-baseline gap-3">
                  <time
                    datetime={item.date}
                    class="font-mono text-xs uppercase tracking-wider text-ink-400"
                  >
                    {formatDate(item.date)}
                  </time>
                  <span class="h-px flex-1 bg-white/5"></span>
                </div>
                <h4 class="mt-1.5 flex items-center gap-2 text-base font-semibold text-white">
                  {/* Lucide icons are React components — `style` must be
                      an object, not a CSS string. */}
                  <Icon size={16} style={{ color: `rgb(${color})` }} />
                  {item.title}
                </h4>
                <p class="mt-1 text-sm text-ink-300">{item.blurb}</p>
              </li>
            );
          })}
        </ol>
      </div>

      {/* ────────────── In-the-lab column ────────────── */}
      <div>
        <div class="mb-5 flex items-center gap-3">
          <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-aurora-purple/15 ring-1 ring-aurora-purple/30">
            <Sparkles size={16} className="text-aurora-purple" />
          </span>
          <h3 class="text-lg font-semibold text-white">In the lab</h3>
        </div>
        <ul class="space-y-4">
          {lab.map((item) => {
            const Icon = item.icon;
            const color = rgb[item.tint];
            return (
              <li class="glass glass-tilt group relative overflow-hidden rounded-2xl p-5">
                {/* Decorative glow blob, positioned top-right. */}
                <span
                  aria-hidden="true"
                  class="pointer-events-none absolute -right-12 -top-12 h-32 w-32 rounded-full opacity-40 transition-opacity duration-500 group-hover:opacity-70"
                  style={`background: radial-gradient(circle, rgba(${color}, 0.45), transparent 70%); filter: blur(16px);`}
                ></span>

                <div class="relative flex items-start gap-4">
                  {/* Tint is conveyed via a CSS custom prop so the
                      span below can reference it via rgba() without
                      inlining a fragile string. */}
                  <span
                    class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl ring-1 ring-white/15"
                    style={`background: rgba(${color}, 0.14);`}
                  >
                    <Icon size={18} style={{ color: `rgb(${color})` }} />
                  </span>
                  <div class="min-w-0 flex-1">
                    <div class="flex flex-wrap items-center gap-2">
                      <h4 class="text-base font-semibold text-white">{item.title}</h4>
                      <span class="pill text-[10px] uppercase tracking-wider">
                        ETA {item.eta}
                      </span>
                    </div>
                    <p class="mt-1 text-sm text-ink-300">{item.blurb}</p>

                    {/* Progress bar — visual cue of how close the feature is. */}
                    <div class="mt-3 h-1 w-full overflow-hidden rounded-full bg-white/5">
                      <div
                        class="h-full rounded-full transition-all duration-1000 ease-out"
                        style={`width: ${item.progress}%; background: linear-gradient(90deg, rgb(${color}), rgba(${color}, 0.5));`}
                        role="progressbar"
                        aria-valuenow={item.progress}
                        aria-valuemin="0"
                        aria-valuemax="100"
                      ></div>
                    </div>
                    <div class="mt-1 text-right font-mono text-[11px] text-ink-400">
                      {item.progress}% complete
                    </div>
                  </div>
                </div>
              </li>
            );
          })}
        </ul>

        <a
          href="https://github.com/voiceink/voiceink/issues"
          class="focus-ring mt-6 inline-flex items-center gap-2 text-sm text-ink-300 hover:text-white"
        >
          <Sparkles size={14} aria-hidden="true" />
          Vote for the next feature on GitHub
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </div>
</section>
