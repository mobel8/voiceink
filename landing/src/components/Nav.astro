---
/**
 * Top navigation — sticky, auto-hides on scroll down, reappears on
 * scroll up (Hide-on-scroll pattern). Includes a glass blur that
 * intensifies as the user scrolls past the hero.
 *
 * Pure Astro + a tiny inline script; no React needed.
 */

const links = [
  { href: '#features',   label: 'Features'   },
  { href: '#how',        label: 'How it works' },
  { href: '#pricing',    label: 'Pricing'    },
  { href: '#roadmap',    label: 'Roadmap'    },
  { href: '#faq',        label: 'FAQ'        },
];
---

<header
  id="nav"
  class="fixed inset-x-0 top-0 z-50 transition-all duration-300"
  data-visible="true"
>
  <div class="container-page px-4 md:px-6">
    <nav
      class="mt-3 flex items-center justify-between gap-3 rounded-2xl border border-white/5 bg-ink-950/40 px-3 py-2.5 backdrop-blur-lg transition-all duration-300 md:px-5"
      id="nav-shell"
    >
      <a href="/" class="focus-ring flex items-center gap-2 rounded-lg px-2 py-1 text-white">
        <span class="relative inline-flex h-7 w-7 items-center justify-center">
          <span class="absolute inset-0 rounded-xl bg-gradient-to-br from-aurora-purple via-aurora-pink to-aurora-cyan opacity-80 blur-sm"></span>
          <span class="relative z-10 inline-flex h-7 w-7 items-center justify-center rounded-xl bg-gradient-to-br from-aurora-purple via-aurora-pink to-aurora-cyan text-[14px] font-bold text-white shadow-inner">V</span>
        </span>
        <span class="text-[15px] font-semibold tracking-tight">VoiceInk</span>
        <span class="pill ml-1 hidden py-0.5 text-[10px] md:inline-flex">v1.7</span>
      </a>

      <ul class="hidden items-center gap-1 md:flex">
        {links.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class="focus-ring rounded-xl px-3 py-1.5 text-sm text-ink-200 transition-colors hover:text-white"
            >
              {label}
            </a>
          </li>
        ))}
      </ul>

      <div class="flex items-center gap-2">
        <a href="https://github.com/mobel8/voiceink" class="focus-ring hidden rounded-xl px-3 py-1.5 text-sm text-ink-200 transition-colors hover:text-white md:inline-block">
          GitHub
        </a>
        <a href="#download" class="btn-primary btn-sm">
          Download Free
        </a>
      </div>
    </nav>
  </div>
</header>

{/* Spacer so content doesn't hide under the nav. */}
<div class="h-20"></div>

<script is:inline>
  /**
   * Hide-on-scroll + blur-intensity controller.
   *
   * Scroll down past threshold → nav slides up (translateY(-100%)).
   * Scroll up                   → nav slides back in.
   * Scroll position > 60        → thicker glass + darker background.
   *
   * We throttle via rAF — `scroll` fires hundreds of times/s on
   * trackpads, and without throttling Lighthouse flags "Document
   * latency > 300ms" from repaints.
   */
  (function () {
    const nav = document.getElementById('nav');
    const shell = document.getElementById('nav-shell');
    if (!nav || !shell) return;
    let lastY = window.scrollY;
    let ticking = false;

    function update() {
      const y = window.scrollY;
      const goingDown = y > lastY && y > 120;
      nav.style.transform = goingDown ? 'translateY(-110%)' : 'translateY(0)';
      if (y > 60) {
        shell.classList.add('border-white/10', 'bg-ink-950/70');
        shell.classList.remove('border-white/5',  'bg-ink-950/40');
      } else {
        shell.classList.add('border-white/5',  'bg-ink-950/40');
        shell.classList.remove('border-white/10', 'bg-ink-950/70');
      }
      lastY = y;
      ticking = false;
    }

    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(update);
        ticking = true;
      }
    }, { passive: true });
  })();
</script>
