---
/**
 * FAQ — native <details>/<summary> accordion.
 *
 * Why native rather than a custom React component:
 *   - Zero JS, zero hydration cost, still fully animated (CSS `grid`
 *     trick for height transition).
 *   - Keyboard accessible by default — Enter/Space open, Tab-in-order.
 *   - SSR-crawlable, good for SEO (rich-results FAQ schema ready).
 *
 * Bonus: we emit a JSON-LD FAQ block at the bottom so Google can
 * render rich-results snippets in search.
 */

const faqs = [
  {
    q: 'How fast is "under 400 ms" really?',
    a: 'We measured tap-to-first-audio-byte on a 50 Mbps fiber connection in Paris. Whisper Turbo on Groq returns the first token in ~170 ms, Cartesia TTS streams the first MP3 chunk in ~180 ms, and our routing adds ~30 ms. You hear the first syllable of the translation before most apps have even reacted to your keypress.',
  },
  {
    q: 'Does VoiceInk work offline?',
    a: 'Not the cloud mode — transcription and TTS need Groq / Cartesia. But with BYOK (Bring Your Own Key) turned on, you can point VoiceInk at your own Whisper running locally via llama.cpp. The pipeline is modular: we\u2019ll ship a local-only mode in v2.0 with whisper.cpp + Piper TTS.',
  },
  {
    q: 'Is my voice recorded and used for training?',
    a: 'No. Audio is transcribed and immediately discarded — we never persist audio to disk on our servers. The Groq and Cartesia providers have the same no-training contract (per their DPA). The transcript itself is kept only for your history and is end-to-end encrypted at rest with keys derived from your account password.',
  },
  {
    q: 'Does it run on Mac / Linux?',
    a: 'Windows ships first (v1.7 today). Mac builds are in QA — we\u2019re waiting on Apple Developer notarization. Linux AppImage + .deb are available in Early Access; full support before Q3 2026.',
  },
  {
    q: 'What happens if I go over my plan limit?',
    a: 'Free users hit a hard stop with a friendly message telling them how many minutes they have left this month. Pro users get soft-warned at 80% and 100%, with the option to enable overage at 0.02 €/min. You\u2019ll never be charged without consenting to the overage first.',
  },
  {
    q: 'Can I cancel anytime?',
    a: 'Yes, right from the app (Settings → Billing → Cancel). Your subscription stays active until the end of your billing period, and we don\u2019t require a phone call or retention chat. No dark patterns, ever.',
  },
  {
    q: 'Do you have an API?',
    a: 'Not publicly — yet. The same endpoints that serve the desktop app can be exposed to third-party developers on the Enterprise plan. Reach out if you want early API access.',
  },
  {
    q: 'How does VoiceInk compare to Otter / Dragon?',
    a: 'Otter is a great meeting transcriber but doesn\u2019t translate or speak. Dragon Medical is accurate but costs 500+ €/yr and hasn\u2019t updated its UI since 2014. VoiceInk is the only one that does dictation + live translation + voice cloning in a single tiny app, for a fraction of the price.',
  },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(({ q, a }) => ({
    '@type': 'Question',
    name: q,
    acceptedAnswer: { '@type': 'Answer', text: a },
  })),
};
---

<section id="faq" class="relative py-20 md:py-32">
  <div class="container-page px-4 md:px-6">
    <div class="mx-auto max-w-2xl text-center">
      <div class="pill mx-auto">FAQ</div>
      <h2 class="mt-4 text-display font-semibold text-white">
        Answers, no fluff.
      </h2>
      <p class="mt-4 text-ink-300 md:text-lg">
        Can\u2019t find what you\u2019re looking for?{' '}
        <a href="mailto:hi@voiceink.app" class="underline decoration-aurora-purple/40 underline-offset-4 hover:text-white">
          Ask us anything
        </a>
        .
      </p>
    </div>

    <div class="mx-auto mt-12 max-w-3xl space-y-3">
      {faqs.map((f) => (
        <details class="glass group rounded-2xl px-5 py-4 transition-colors [&[open]]:bg-white/[0.04]">
          <summary class="focus-ring flex cursor-pointer list-none items-center justify-between gap-4">
            <span class="text-sm font-semibold text-white md:text-base">{f.q}</span>
            <span class="flex h-7 w-7 flex-none items-center justify-center rounded-full border border-white/10 bg-white/5 transition-transform duration-300 group-open:rotate-45">
              <svg viewBox="0 0 24 24" class="h-3.5 w-3.5 text-ink-200" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true">
                <path d="M12 5v14M5 12h14" />
              </svg>
            </span>
          </summary>
          <div class="grid grid-rows-[1fr] pt-3 text-sm leading-relaxed text-ink-300">
            {f.a}
          </div>
        </details>
      ))}
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(schema)} is:inline />
</section>
