---
const year = new Date().getUTCFullYear();
const cols = [
  {
    title: 'Product',
    links: [
      { href: '#features', label: 'Features' },
      { href: '#pricing',  label: 'Pricing'  },
      { href: '#download', label: 'Download' },
      { href: '/changelog', label: 'Changelog' },
    ],
  },
  {
    title: 'Use cases',
    links: [
      { href: '/for/creators',  label: 'Creators' },
      { href: '/for/doctors',   label: 'Doctors'  },
      { href: '/for/lawyers',   label: 'Lawyers'  },
      { href: '/for/managers',  label: 'Managers' },
    ],
  },
  {
    title: 'Company',
    links: [
      { href: '/about',   label: 'About'   },
      { href: '/blog',    label: 'Blog'    },
      { href: '/contact', label: 'Contact' },
      { href: 'mailto:hi@voiceink.app', label: 'hi@voiceink.app' },
    ],
  },
  {
    title: 'Legal',
    links: [
      { href: '/privacy',  label: 'Privacy'   },
      { href: '/terms',    label: 'Terms'     },
      { href: '/security', label: 'Security'  },
      { href: '/dpa',      label: 'DPA'       },
    ],
  },
];
---

<footer class="relative z-10 mt-32 border-t border-white/5">
  <div class="container-page px-4 pt-16 pb-10 md:px-6">
    <div class="grid grid-cols-2 gap-8 md:grid-cols-5">
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="inline-flex items-center gap-2 text-white">
          <span class="relative inline-flex h-8 w-8 items-center justify-center">
            <span class="absolute inset-0 rounded-xl bg-gradient-to-br from-aurora-purple via-aurora-pink to-aurora-cyan opacity-80 blur-sm"></span>
            <span class="relative z-10 inline-flex h-8 w-8 items-center justify-center rounded-xl bg-gradient-to-br from-aurora-purple via-aurora-pink to-aurora-cyan font-bold text-white">V</span>
          </span>
          <span class="text-lg font-semibold tracking-tight">VoiceInk</span>
        </a>
        <p class="mt-4 max-w-xs text-sm text-ink-300">
          The fastest voice-to-voice translator on your desktop. Built in
          Paris, crafted for speed.
        </p>
        <div class="mt-5 flex items-center gap-3">
          <a href="https://twitter.com/voiceinkapp" class="focus-ring rounded-lg p-2 text-ink-300 transition-colors hover:text-white" aria-label="Twitter">
            <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://github.com/mobel8/voiceink" class="focus-ring rounded-lg p-2 text-ink-300 transition-colors hover:text-white" aria-label="GitHub">
            <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true"><path d="M12 .5A11.5 11.5 0 0 0 .5 12a11.5 11.5 0 0 0 7.86 10.917c.575.107.786-.25.786-.554v-1.946c-3.198.696-3.873-1.544-3.873-1.544-.523-1.329-1.277-1.683-1.277-1.683-1.045-.714.079-.7.079-.7 1.155.081 1.764 1.186 1.764 1.186 1.027 1.76 2.694 1.253 3.352.958.104-.744.402-1.253.73-1.541-2.553-.29-5.238-1.277-5.238-5.685 0-1.256.448-2.283 1.183-3.088-.119-.291-.513-1.462.112-3.05 0 0 .965-.309 3.164 1.18a10.98 10.98 0 0 1 5.76 0c2.196-1.489 3.16-1.18 3.16-1.18.627 1.588.233 2.759.114 3.05.738.805 1.181 1.832 1.181 3.088 0 4.418-2.69 5.392-5.252 5.676.413.356.78 1.058.78 2.133v3.16c0 .307.208.667.79.553A11.5 11.5 0 0 0 23.5 12 11.5 11.5 0 0 0 12 .5z"/></svg>
          </a>
        </div>
      </div>
      {cols.map((col) => (
        <div>
          <h4 class="mb-3 text-sm font-semibold text-white">{col.title}</h4>
          <ul class="space-y-2">
            {col.links.map((l) => (
              <li>
                <a href={l.href} class="focus-ring rounded text-sm text-ink-300 transition-colors hover:text-white">
                  {l.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    <div class="mt-12 flex flex-col items-start justify-between gap-4 border-t border-white/5 pt-6 md:flex-row md:items-center">
      <p class="text-xs text-ink-400">© {year} VoiceInk. Built in Paris with care.</p>
      <p class="text-xs text-ink-400">
        &lt;400 ms voice-to-voice — on commodity hardware.
      </p>
    </div>
  </div>
</footer>
