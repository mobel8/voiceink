---
/**
 * BlogPreview — shows the 3 most recent blog posts as magazine-style
 * cards directly on the home page. Drives SEO traffic deeper into the
 * site and demonstrates that we ship content regularly.
 *
 * Pulled live from Astro's content collection at build-time; no
 * manual duplication to maintain.
 */
import { getCollection } from 'astro:content';
import { ArrowUpRight, Calendar, Clock } from 'lucide-react';

const allPosts = await getCollection('blog', (p) => p.data.published !== false);
const posts = allPosts
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const categoryLabel: Record<string, string> = {
  'guide':              'Guide',
  'comparison':         'Comparison',
  'vertical-health':    'Healthcare',
  'vertical-legal':     'Legal',
  'vertical-creators':  'Creators',
  'vertical-teams':     'Teams',
  'announcement':       'Announcement',
  'tutorial':           'Tutorial',
};

const categoryTint: Record<string, string> = {
  'guide':              'from-aurora-cyan to-aurora-blue',
  'comparison':         'from-aurora-purple to-aurora-pink',
  'vertical-health':    'from-emerald-400 to-aurora-cyan',
  'vertical-legal':     'from-aurora-amber to-aurora-pink',
  'vertical-creators':  'from-aurora-pink to-aurora-amber',
  'vertical-teams':     'from-aurora-blue to-aurora-purple',
  'announcement':       'from-aurora-purple to-aurora-cyan',
  'tutorial':           'from-aurora-cyan to-aurora-pink',
};
---

<section id="blog" class="relative py-20 md:py-32" aria-labelledby="blog-title">
  <div class="container-page px-4 md:px-6">
    <div class="mb-10 flex flex-col items-start justify-between gap-4 md:mb-14 md:flex-row md:items-end">
      <div>
        <span class="pill">
          <span class="text-aurora-cyan">●</span> Writing
        </span>
        <h2 id="blog-title" class="mt-3 font-display text-display font-semibold text-white">
          From the <span class="text-gradient">VoiceInk journal</span>
        </h2>
        <p class="mt-3 max-w-xl text-base text-ink-300 md:text-lg">
          Deep-dives on real-time voice AI, latency engineering, and the dictation
          workflows of doctors, lawyers, creators and engineers.
        </p>
      </div>
      <a href="/blog/" class="btn-secondary focus-ring btn-sm group">
        Read all articles
        <ArrowUpRight size={16} class="transition-transform duration-200 group-hover:-translate-y-0.5 group-hover:translate-x-0.5" />
      </a>
    </div>

    <div class="grid gap-5 md:grid-cols-3">
      {posts.map((post, i) => (
        <a
          href={`/blog/${post.slug}/`}
          class="group relative flex flex-col overflow-hidden rounded-2xl border border-white/8 bg-ink-900/50 p-6 transition-all duration-300 hover:-translate-y-1 hover:border-white/20 hover:shadow-[0_20px_50px_-20px_rgba(167,139,250,0.55)]"
          style={`animation: fadeUp 700ms cubic-bezier(0.22,1,0.36,1) ${i * 100}ms both;`}
        >
          {/* Gradient category label */}
          <div class="mb-4 flex items-center justify-between">
            <span class={`inline-flex items-center gap-1 rounded-full border border-white/10 bg-gradient-to-br ${categoryTint[post.data.category] ?? 'from-aurora-purple to-aurora-cyan'} bg-clip-text px-2.5 py-1 text-[11px] font-semibold uppercase tracking-wider text-transparent`}>
              {categoryLabel[post.data.category] ?? post.data.category}
            </span>
            <ArrowUpRight size={16} class="text-ink-400 transition-all duration-300 group-hover:-translate-y-0.5 group-hover:translate-x-0.5 group-hover:text-white" />
          </div>

          <h3 class="font-display text-xl font-semibold leading-tight text-white transition-colors group-hover:text-white">
            {post.data.title}
          </h3>
          <p class="mt-3 flex-1 text-sm text-ink-300">{post.data.description}</p>

          <div class="mt-6 flex items-center gap-4 text-xs text-ink-400">
            <span class="inline-flex items-center gap-1.5">
              <Calendar size={12} />
              {new Date(post.data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
            </span>
            {post.data.readingTime && (
              <span class="inline-flex items-center gap-1.5">
                <Clock size={12} />
                {post.data.readingTime}
              </span>
            )}
          </div>

          {/* Aurora hover corner */}
          <span
            aria-hidden="true"
            class="pointer-events-none absolute -right-12 -top-12 h-32 w-32 rounded-full opacity-0 blur-2xl transition-opacity duration-500 group-hover:opacity-60"
            style="background: radial-gradient(circle, rgba(167,139,250,0.6), transparent);"
          ></span>
        </a>
      ))}
    </div>
  </div>
</section>
