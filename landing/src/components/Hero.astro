---
/**
 * Hero — the single most important 1000 px of the site.
 *
 * Anatomy (top-to-bottom):
 *   1. Aurora blob background (3 animated radial gradients)
 *   2. Noise overlay (kills OLED banding)
 *   3. Grid pattern (barely visible, gives depth)
 *   4. Floating orbit pill (decorative, screen ≥ lg)
 *   5. Announcement pill ("New: AI voice cloning")
 *   6. H1 with gradient accent on the key noun
 *   7. Subheadline, 2 lines max at any viewport
 *   8. CTA duo (primary download, secondary watch demo)
 *   9. Trust badges strip ("As featured on …")
 *  10. Interactive voice-demo widget (React island, hydrates on visible)
 *
 * Key accessibility decisions:
 *   - All decorative elements (blobs, orbit) have `aria-hidden`.
 *   - Typing effect respects prefers-reduced-motion (shown statically).
 *   - CTA buttons are buttons, not styled links, so keyboard users get
 *     proper Enter-key activation without the link's default behaviors.
 */
import VoiceDemo from './VoiceDemo.tsx';
import { Mic, Play, Download, ArrowRight, Zap, Globe, Sparkles } from 'lucide-react';
---

<section
  class="noise-overlay relative isolate overflow-hidden pt-10 pb-24 md:pt-16 md:pb-32"
  aria-labelledby="hero-title"
>
  {/* Aurora blobs — pure CSS, GPU-only. */}
  <div class="absolute inset-0 -z-10" aria-hidden="true">
    <div
      class="aurora-blob animate-aurora"
      style="width: 60vw; height: 60vw; left: -10vw; top: -10vw; background: radial-gradient(circle, rgba(167,139,250,0.75), transparent 60%);"
    ></div>
    <div
      class="aurora-blob animate-aurora"
      style="width: 55vw; height: 55vw; right: -15vw; top: 5vw; background: radial-gradient(circle, rgba(34,211,238,0.5), transparent 60%); animation-delay: -6s;"
    ></div>
    <div
      class="aurora-blob animate-aurora"
      style="width: 50vw; height: 50vw; left: 20vw; bottom: -15vw; background: radial-gradient(circle, rgba(244,114,182,0.45), transparent 60%); animation-delay: -12s;"
    ></div>
  </div>

  {/* Subtle grid pattern. */}
  <div
    class="absolute inset-0 -z-10 bg-grid-line opacity-[0.35] [mask-image:radial-gradient(ellipse_at_center,black_30%,transparent_75%)]"
    style="background-size: 64px 64px;"
    aria-hidden="true"
  ></div>

  <div class="container-page px-4 md:px-6">
    <div class="grid items-center gap-10 md:grid-cols-[1.1fr_1fr] md:gap-12 lg:gap-20">
      <div class="text-center md:text-left">
        {/* Announcement pill */}
        <a
          href="#features"
          class="animate-fade-up pill-glow focus-ring inline-flex gap-2 px-3.5 py-1.5 transition-transform hover:scale-[1.02]"
        >
          <Sparkles size={12} aria-hidden="true" className="text-fuchsia-300" />
          <span>New: voice cloning in 30 languages</span>
          <ArrowRight size={12} aria-hidden="true" className="opacity-70" />
        </a>

        <h1
          id="hero-title"
          class="animate-fade-up delay-100 mt-5 text-balance font-display text-hero font-semibold text-white"
        >
          Speak once.
          <span class="text-gradient"> The world understands. </span>
          <span class="block text-ink-100">Instantly.</span>
        </h1>

        <p class="animate-fade-up delay-200 mt-5 max-w-xl text-base text-ink-300 md:text-lg mx-auto md:mx-0">
          VoiceInk is a desktop app that transcribes, translates and speaks back
          in <strong class="text-white">under 400&nbsp;ms</strong>. Dictate with a
          tap, interpret live conversations, or double your videos in 30&nbsp;languages
          with your own voice.
        </p>

        <div class="animate-fade-up delay-300 mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row md:justify-start">
          <a href="#download" class="btn-primary focus-ring">
            <Download size={18} aria-hidden="true" />
            Download for Windows
            <span class="ml-1 rounded-md bg-white/15 px-1.5 py-0.5 text-[11px] font-semibold">
              Free
            </span>
          </a>
          <a href="#demo" class="btn-secondary focus-ring">
            <Play size={16} aria-hidden="true" />
            Watch 60s demo
          </a>
        </div>

        <div class="animate-fade-up delay-400 mt-6 flex flex-wrap items-center justify-center gap-x-5 gap-y-2 text-xs text-ink-400 md:justify-start">
          <span class="inline-flex items-center gap-1.5"><Zap size={12} className="text-aurora-cyan" />&lt;400 ms voice-to-voice</span>
          <span class="inline-flex items-center gap-1.5"><Globe size={12} className="text-aurora-purple" />30+ languages</span>
          <span class="inline-flex items-center gap-1.5"><Mic size={12} className="text-aurora-pink" />Works offline with your own keys</span>
        </div>
      </div>

      {/* Interactive demo — React island, hydrated on visible. */}
      <div class="animate-fade-up delay-300">
        <VoiceDemo client:visible />
      </div>
    </div>
  </div>
</section>
